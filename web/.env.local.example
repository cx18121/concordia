# Copy this file to web/.env.local (gitignored) and fill in the REPLACE_ME values.
# Nothing here is real — these are the keys Track A (identity + wallet) needs.

# --- Dynamic (dynamic.xyz) ---
# Create a project, enable Email login + Embedded wallets, turn on "Create on Sign up",
# and enable Base Sepolia. Copy the environment ID here.
NEXT_PUBLIC_DYNAMIC_ENVIRONMENT_ID=REPLACE_ME

# --- World ID (developer.world.org -> Developer Portal) ---
# Create an app + an Incognito Action. Request level must be `selfieCheckLegacy`
# with `allow_legacy_proofs: true` (NOT `orb`) — the widget already uses
# allow_legacy_proofs={true} + deviceLegacy(), leave that as-is.
# Server-only (used by /api/rp-signature + /api/verify):
WORLD_RP_ID=REPLACE_ME
RP_SIGNING_KEY=REPLACE_ME
# Client (read by WorldIDVerify):
NEXT_PUBLIC_WORLD_APP_ID=app_REPLACE_ME
NEXT_PUBLIC_WORLD_ACTION=REPLACE_ME

# Demo escape hatch: lets verify() flip isVerified without a real World proof.
# Keep true to click through the flow; set false to require a real proof.
NEXT_PUBLIC_DEV_BYPASS=true
