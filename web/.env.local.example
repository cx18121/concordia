# Copy this file to web/.env.local (gitignored) and fill in the REPLACE_ME values.
# Nothing here is real — these are the keys Track A (identity + wallet) needs.

# --- Dynamic (dynamic.xyz) ---
# Create a project, enable Email login + Embedded wallets, turn on "Create on Sign up",
# and enable Base Sepolia. Copy the environment ID here.
NEXT_PUBLIC_DYNAMIC_ENVIRONMENT_ID=REPLACE_ME

# --- World ID (developer.world.org -> Developer Portal) ---
# Create an app + an Incognito Action. Request level must be `selfieCheckLegacy`
# with `allow_legacy_proofs: true` (NOT `orb`) — the widget already uses
# allow_legacy_proofs={true} + deviceLegacy(), leave that as-is.
# Server-only (used by /api/rp-signature + /api/verify):
WORLD_RP_ID=REPLACE_ME
RP_SIGNING_KEY=REPLACE_ME
# Client (read by WorldIDVerify):
NEXT_PUBLIC_WORLD_APP_ID=app_REPLACE_ME
NEXT_PUBLIC_WORLD_ACTION=REPLACE_ME

# Demo escape hatch: lets verify() flip isVerified without a real World proof.
# Keep true to click through the flow; set false to require a real proof.
NEXT_PUBLIC_DEV_BYPASS=true

# --- Data layer: mock vs live (lib/data.ts) ---
# Leave unset/true for the mock demo. Set to "false" ONLY once the live adapter
# is wired (B7) AND contracts are deployed (they are) AND the keeper is running.
NEXT_PUBLIC_USE_MOCK=true
# Base Sepolia RPC for live reads/writes. Public default is rate-limited — use a
# real Alchemy/Coinbase endpoint for an always-on demo. Read by @concordia/shared.
RPC_URL=https://sepolia.base.org

# --- On-chain World ID bridge (server-only, used by /api/verify) ---
# FundVault.verify(user) is onlyAdmin — after the World REST check passes, the
# route must mark the wallet verified on-chain or live deposits revert NotVerified.
# This must be the SAME key set as FundVault.admin at deploy (= keeper/.env KEEPER_KEY).
# Leave blank in mock.
ADMIN_PRIVATE_KEY=

# --- New-user gas drip (server-only, used by /api/verify) ---
# Preferred: /api/verify funds the new user's gas straight from the CDP faucet
# (0.0001 ETH/claim, 1000/day) so the admin wallet isn't drained. From the CDP portal
# (portal.cdp.coinbase.com). If unset, drip falls back to a transfer from ADMIN_PRIVATE_KEY.
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=
