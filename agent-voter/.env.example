# OPTIONAL — only needed if you want to use Claude instead of a local Ollama model.
# Copy this file to .env and paste your Anthropic key. The voter reads it
# server-side; it is never shown in or entered through the dashboard.
# .env is gitignored — do not commit it.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: point at a non-default Ollama host (defaults to http://localhost:11434).
# OLLAMA_URL=http://localhost:11434
